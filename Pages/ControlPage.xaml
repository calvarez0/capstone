<Page x:Class="WPF_GUI.Pages.ControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WPF_GUI.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <!-- Page Header -->
            <TextBlock Text="Valve Control &amp; Monitoring" FontSize="28" FontWeight="Bold" Foreground="#2c3e50"/>
            <TextBlock Text="Real-time control and status monitoring of S7X actuator"
                       FontSize="14" Foreground="#7f8c8d" Margin="0,5,0,20"/>

            <!-- Control Grid -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Visual Indicators Card -->
                <Border Grid.Row="0" Grid.Column="0" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Visual Indicators" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <!-- Valve Position -->
                        <TextBlock Text="Valve Position" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Height="30" Margin="0,0,0,5">
                            <Grid>
                                <Border x:Name="PositionFill" Background="#3498db" CornerRadius="2" HorizontalAlignment="Left" Width="0"/>
                                <TextBlock x:Name="PositionValue" Text="50.0%" FontWeight="SemiBold"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Closed (0%)" FontSize="11" Foreground="#6c757d" Grid.Column="0"/>
                            <TextBlock Text="Open (100%)" FontSize="11" Foreground="#6c757d" Grid.Column="1" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Torque -->
                        <TextBlock Text="Torque" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Height="30" Margin="0,0,0,15">
                            <Grid>
                                <Border x:Name="TorqueFill" Background="#27ae60" CornerRadius="2" HorizontalAlignment="Left" Width="0"/>
                                <TextBlock x:Name="TorqueValue" Text="45.0%" FontWeight="SemiBold"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Current Status -->
                        <TextBlock Text="Current Status" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border x:Name="StatusBadge" Background="#95a5a6" CornerRadius="4" Padding="10" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="Stopped" FontSize="16" FontWeight="SemiBold"
                                      Foreground="White" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Control Buttons Card -->
                <Border Grid.Row="0" Grid.Column="2" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Valve Commands" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <Button x:Name="OpenButton" Click="OpenButton_Click" Margin="0,0,0,10" Padding="15"
                                Background="#27ae60" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#27ae60"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="▲" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                                                        <TextBlock Text="OPEN" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#229954"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#95a5a6"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="StopButton" Click="StopButton_Click" Margin="0,0,0,10" Padding="15"
                                Background="#f39c12" BorderThickness="0" IsEnabled="False" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#f39c12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="■" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                                                        <TextBlock Text="STOP" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e67e22"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#95a5a6"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="CloseButton" Click="CloseButton_Click" Padding="15"
                                Background="#e74c3c" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#e74c3c"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="▼" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                                                        <TextBlock Text="CLOSE" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#c0392b"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#95a5a6"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border Background="#fff3cd" BorderBrush="#ffc107" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Commands are sent via Modbus RTU protocol" FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock Text="Function Code 05 - Force Single Coil" FontSize="11" Foreground="#856404"
                                          TextAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Bits Card -->
                <Border Grid.Row="2" Grid.Column="0" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Status Bits" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <StackPanel x:Name="StatusBitsPanel">
                            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="PowerBit" Width="12" Height="12" Fill="#27ae60" Margin="0,0,10,0"/>
                                    <TextBlock Text="Power OK" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="CommunicationBit" Width="12" Height="12" Fill="#27ae60" Margin="0,0,10,0"/>
                                    <TextBlock Text="Communication" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="CalibratedBit" Width="12" Height="12" Fill="#27ae60" Margin="0,0,10,0"/>
                                    <TextBlock Text="Calibrated" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="MovingBit" Width="12" Height="12" Fill="#95a5a6" Margin="0,0,10,0"/>
                                    <TextBlock Text="Moving" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="OpenLimitBit" Width="12" Height="12" Fill="#95a5a6" Margin="0,0,10,0"/>
                                    <TextBlock Text="Open Limit" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="CloseLimitBit" Width="12" Height="12" Fill="#95a5a6" Margin="0,0,10,0"/>
                                    <TextBlock Text="Close Limit" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Alarms & Alerts Card -->
                <Border Grid.Row="2" Grid.Column="2" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Alarms &amp; Alerts" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <Border Background="#d4edda" BorderBrush="#c3e6cb" BorderThickness="1" CornerRadius="4" Padding="20">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✓" FontSize="28" Foreground="#155724" HorizontalAlignment="Center"/>
                                <TextBlock Text="No active alarms" Foreground="#155724" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Monitored Conditions:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Text="• Over-torque protection" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="• Communication timeout" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="• Position sensor errors" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="• Temperature warnings" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
