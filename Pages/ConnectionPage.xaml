<Page x:Class="WPF_GUI.Pages.ConnectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WPF_GUI.Pages"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <!-- Page Header -->
            <TextBlock Text="Connection Configuration" FontSize="28" FontWeight="Bold" Foreground="#2c3e50"/>
            <TextBlock Text="Configure serial port and Modbus settings to connect to S7X actuator"
                       FontSize="14" Foreground="#7f8c8d" Margin="0,5,0,20"/>

            <!-- Connection Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Serial Port Settings Card -->
                <Border Grid.Column="0" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Serial Port Settings" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <!-- COM Port Number -->
                        <TextBlock Text="COM Port Number" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="PortNumberBox" Text="1" Padding="8" FontSize="14" Margin="0,0,0,5"/>
                        <TextBlock Text="Available ports: COM1, COM2, COM3..." FontSize="11" Foreground="#6c757d" Margin="0,0,0,15"/>

                        <!-- Baud Rate -->
                        <TextBlock Text="Baud Rate" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="BaudRateCombo" SelectedIndex="1" Padding="8" FontSize="14" Margin="0,0,0,15">
                            <ComboBoxItem Content="4800"/>
                            <ComboBoxItem Content="9600 (Default)"/>
                            <ComboBoxItem Content="19200"/>
                            <ComboBoxItem Content="38400"/>
                            <ComboBoxItem Content="115200"/>
                        </ComboBox>

                        <!-- Parity -->
                        <TextBlock Text="Parity" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ParityCombo" SelectedIndex="0" Padding="8" FontSize="14" Margin="0,0,0,15">
                            <ComboBoxItem Content="None (Default)"/>
                            <ComboBoxItem Content="Even"/>
                            <ComboBoxItem Content="Odd"/>
                        </ComboBox>

                        <!-- Stop Bits -->
                        <TextBlock Text="Stop Bits" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="StopBitsCombo" SelectedIndex="0" Padding="8" FontSize="14">
                            <ComboBoxItem Content="1 (Default)"/>
                            <ComboBoxItem Content="2"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Modbus Configuration Card -->
                <Border Grid.Column="2" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Modbus Configuration" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <!-- Slave Modbus Address -->
                        <TextBlock Text="Slave Modbus Address" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ModbusAddressBox" Text="254" Padding="8" FontSize="14" Margin="0,0,0,5"
                                 PreviewTextInput="NumberValidationTextBox"/>
                        <TextBlock Text="Valid range: 1-254 (Default: 254)" FontSize="11" Foreground="#6c757d" Margin="0,0,0,20"/>

                        <!-- Protocol Information -->
                        <TextBlock Text="Protocol Information" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Border Background="White" CornerRadius="3" Padding="15" BorderBrush="#dee2e6" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Protocol:" FontWeight="SemiBold" Grid.Column="0" Margin="0,0,10,0"/>
                                    <TextBlock Text="Modbus RTU" Grid.Column="1"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Interface:" FontWeight="SemiBold" Grid.Column="0" Margin="0,0,10,0"/>
                                    <TextBlock Text="RS485" Grid.Column="1"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CRC Check:" FontWeight="SemiBold" Grid.Column="0" Margin="0,0,10,0"/>
                                    <TextBlock Text="16-bit Enabled" Grid.Column="1"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Connection Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,20">
                <Button x:Name="ConnectButton" Content="Open Port" Click="ConnectButton_Click"
                        Background="#3498db" Foreground="White" Padding="30,12" FontSize="14"
                        FontWeight="SemiBold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3498db"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2980b9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#95a5a6"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="DisconnectButton" Content="Close Port" Click="DisconnectButton_Click"
                        Background="#95a5a6" Foreground="White" Padding="30,12" FontSize="14"
                        FontWeight="SemiBold" BorderThickness="0" IsEnabled="False" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#95a5a6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7f8c8d"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#bdc3c7"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Status Message -->
            <Border x:Name="StatusBorder" Visibility="Collapsed" Background="#d4edda" BorderBrush="#c3e6cb"
                    BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusIcon" Text="✓" FontSize="18" FontWeight="Bold"
                               Foreground="#155724" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#155724" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
