<Page x:Class="WPF_GUI.Pages.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WPF_GUI.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <!-- Page Header -->
            <TextBlock Text="Network Visualization" FontSize="28" FontWeight="Bold" Foreground="#2c3e50"/>
            <TextBlock Text="Monitor and troubleshoot multiple Modbus actuators on the network"
                       FontSize="14" Foreground="#7f8c8d" Margin="0,5,0,20"/>

            <!-- Network Controls -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Polling Configuration Card -->
                <Border Grid.Column="0" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Polling Configuration" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Number of Devices" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="NumberOfDevicesBox" Text="4" Padding="8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Polling Direction" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="PollingDirectionCombo" SelectedIndex="0" Padding="8">
                                    <ComboBoxItem Content="Forward"/>
                                    <ComboBoxItem Content="Backward"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Custom Address Sequence" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="CustomSequenceBox" Text="1,2,3,4" Padding="8" Margin="0,0,0,5"/>
                        <TextBlock Text="Comma-separated device addresses" FontSize="11" Foreground="#6c757d" Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="StartPollingButton" Content="▶ Start Polling" Click="StartPollingButton_Click"
                                    Background="#27ae60" Foreground="White" Padding="20,10" FontSize="14"
                                    BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#27ae60"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#229954"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#95a5a6"/>
                                                <Setter Property="Cursor" Value="Arrow"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="StopPollingButton" Content="■ Stop Polling" Click="StopPollingButton_Click"
                                    Background="#e74c3c" Foreground="White" Padding="20,10" FontSize="14"
                                    BorderThickness="0" IsEnabled="False" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#e74c3c"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#c0392b"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#95a5a6"/>
                                                <Setter Property="Cursor" Value="Arrow"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <Border x:Name="PollingIndicator" Visibility="Collapsed" Background="#d1ecf1" BorderBrush="#bee5eb"
                                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#0c5460" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                           From="1" To="0.2" Duration="0:0:1"
                                                                           AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="Polling active - updating every 2s" Foreground="#0c5460" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Legend Card -->
                <Border Grid.Column="2" Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Legend" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Fill="#27ae60" Margin="0,0,10,0"/>
                                <TextBlock Text="Active Device" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Fill="#95a5a6" Margin="0,0,10,0"/>
                                <TextBlock Text="Inactive/No Response" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="30" Height="3" Fill="#27ae60" Margin="0,0,10,0"/>
                                <TextBlock Text="Connected" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="3" Padding="10">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="30" Height="3" Fill="#e74c3c" Margin="0,0,10,0"/>
                                <TextBlock Text="Connection Failed" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Network Visualization -->
            <Border Background="#f8f9fa" CornerRadius="5" Padding="20" BorderBrush="#dee2e6" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Network Topology" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" Margin="0,0,0,15"/>

                    <!-- Devices Container -->
                    <ItemsControl x:Name="DevicesPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- Network Info -->
                    <Border Background="White" BorderBrush="#dee2e6" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock>
                                <Run Text="Protocol: " FontWeight="SemiBold"/>
                                <Run Text="Modbus RTU - Reading Register 100 for Product Identifier"/>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="Active Devices: " FontWeight="SemiBold"/>
                                <Run x:Name="ActiveDevicesText" Text="0 / 0"/>
                            </TextBlock>
                            <TextBlock Text="💡 Click on any device icon to view its configuration" Margin="0,5,0,0"
                                      FontSize="12" Foreground="#6c757d"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
